# PIA credentials (Gluetun)
PIA_USER=your_pia_username
PIA_PASS=your_pia_password

# Tailscale auth key for exit nodes (reusable, pre-authorized)
# Create at: https://login.tailscale.com/admin/settings/keys
# Recommended tags: tag:exit-node
TS_AUTHKEY=tskey-auth-xxxxxxxx

# Your home LAN CIDR (for Gluetun firewall allowlist)
LAN_CIDR=192.168.1.0/24

# Controller API secret for initial admin pairing (optional)
CONTROLLER_SECRET=change-me-to-a-long-random-string

# Base port for Tailscale UDP per region (incremented per region)
TS_BASE_PORT=41641

# Absolute path to runtime/ on the Linux Docker host (required for regional stacks)
# Example: /home/ashton/tailscale-pia-controller/runtime
HOST_RUNTIME_DIR=/path/to/tailscale-pia-controller/runtime
