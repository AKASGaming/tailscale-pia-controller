# PIA credentials (Gluetun)
PIA_USER=your_pia_username
PIA_PASS=your_pia_password

# Tailscale auth key for exit nodes (reusable, pre-authorized, must include tag below)
# Create at: https://login.tailscale.com/admin/settings/keys
# Example: tskey-auth-xxxx?tags=tag:pia-exit
TS_AUTHKEY=tskey-auth-xxxxxxxx

# Your home LAN CIDR (for Gluetun firewall allowlist)
LAN_CIDR=192.168.1.0/24

# Controller API secret for device registration.
# Leave empty to allow open registration on your LAN.
# If set, the value is shown on the web dashboard at http://your-host:8090/
CONTROLLER_SECRET=

# Base port for Tailscale UDP per region (incremented per region)
TS_BASE_PORT=41641

HOST_RUNTIME_DIR=/path/to/tailscale-pia-controller/runtime

# Docker Compose project name for regional container labels (Portainer grouping)
DOCKER_PROJECT_NAME=tailscale-pia-controller

# Tailscale tag applied to exit nodes — pair with ACL autoApprovers (docs/tailscale-acl.example.json)
TS_EXIT_NODE_TAG=tag:pia-exit
